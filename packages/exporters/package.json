{
  "name": "@reaatech/otel-genai-semconv-exporters",
  "version": "0.1.0",
  "description": "Dashboard exporters for Phoenix, Langfuse, and Cloud Trace",
  "license": "MIT",
  "author": "Rick Somers <rick@reaatech.com> (https://reaatech.com)",
  "repository": {
    "type": "git",
    "url": "https://github.com/reaatech/otel-genai-semconv.git",
    "directory": "packages/exporters"
  },
  "homepage": "https://github.com/reaatech/otel-genai-semconv/tree/main/packages/exporters#readme",
  "bugs": { "url": "https://github.com/reaatech/otel-genai-semconv/issues" },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/sdk-trace-base": "^2.7.0",
    "@reaatech/otel-genai-semconv-core": "workspace:*",
    "@reaatech/otel-genai-semconv-observability": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
